{
  "name": "Menura",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "lint": "eslint .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build:android": "cd android && ./gradlew bundleRelease",
    "build:android:apk": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "clean:android": "cd android && ./gradlew clean",
    "fonts:link": "react-native-asset",
    "check:i18n:recipes": "npx tsx scripts/checkRecipeTranslationCoverage.ts",
    "check:i18n:localized": "npx tsx scripts/checkLocalizedRecipes.ts",
    "check:i18n:translations": "npx tsx scripts/checkTranslations.ts",
    "check:i18n:residuals": "npx tsx scripts/auditTranslationResiduals.ts",
    "check:all": "npm run typecheck && npm run check:i18n:recipes && npm run check:i18n:localized",
    "images:optimize": "node scripts/optimize-recipe-images.mjs",
    "images:map": "node scripts/generate-recipe-image-map.mjs",
    "images:build": "npm run images:optimize && npm run images:map"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-vector-icons/ionicons": "^13.1.1",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@types/react-native-sqlite-storage": "^6.0.5",
    "i18next": "^25.8.13",
    "react": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-iap": "^14.7.20",
    "react-native-localize": "^3.3.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.0.9",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-svg": "15.12.1",
    "react-native-webview": "^13.13.5",
    "uuid": "^11.0.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/eslint-config": "0.81.5",
    "@react-native/metro-config": "0.81.5",
    "@react-native/typescript-config": "0.81.5",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/uuid": "^10.0.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-asset": "^2.2.15",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
